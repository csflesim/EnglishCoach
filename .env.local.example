# 複製此檔為 .env.local 並填入金鑰，然後重啟 dev server（cp .env.local.example .env.local）
# 部署到 Vercel 時，把這些設成 Vercel 專案的 Environment Variables。

# ── AI 評分（可選）。不填則自動以免費模式運行 ──
OPENAI_API_KEY=sk-your-key-here

# ── Supabase（可選）。不填則資料存瀏覽器 localStorage ──
# Supabase 專案 → Project Settings → API 取得
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
